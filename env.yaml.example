# DeepForge Configuration
# ========================
# Copy this file to env.yaml and fill in your credentials.
#
# Priority: CLI args > env.yaml > environment variables > defaults
#
# Usage:
#   python cli.py                              # Auto-discovers env.yaml
#   python cli.py --config env.azure.yaml      # Explicit config file
#   python cli.py --backend azure              # CLI override

# ── Backend Selection ──────────────────────────────────────────────
# deepseek or azure
backend: deepseek

# ── DeepSeek API ───────────────────────────────────────────────────
deepseek:
  # Your DeepSeek API key (from https://platform.deepseek.com)
  api_key: ""
  # API base URL (default: https://api.deepseek.com/v1)
  base_url: "https://api.deepseek.com/v1"
  # Model name: deepseek-chat or deepseek-reasoner
  model: "deepseek-chat"
  # Max output tokens per response (default: 8192)
  max_output_tokens: 8192

# ── Azure OpenAI API ───────────────────────────────────────────────
# Uncomment and fill in to use Azure Foundry (AI Hub).
# Also set backend: azure above.
# azure:
#   endpoint: "https://YOUR-RESOURCE.openai.azure.com/openai/v1/"
#   api_key: ""
#   api_version: "2025-01-01-preview"
#   deployment: "gpt-4o"
#   max_output_tokens: 4096

# ── Mode & Approval ────────────────────────────────────────────────
# mode: agent       # agent (autonomous), plan (read-only), yolo (full auto)
# approval_policy: suggest  # auto, suggest, never

# ── Workspace ──────────────────────────────────────────────────────
# workspace: /path/to/your/project

# ── Tool Settings ──────────────────────────────────────────────────
# shell_enabled: true
# max_parallel_tools: 10
# tool_timeout_seconds: 30
